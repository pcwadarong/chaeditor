{
  "name": "chaeditor",
  "description": "Composable markdown editor toolkit for React applications.",
  "license": "MIT",
  "homepage": "https://github.com/pcwadarong/chaeditor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pcwadarong/chaeditor.git"
  },
  "bugs": {
    "url": "https://github.com/pcwadarong/chaeditor/issues"
  },
  "keywords": [
    "editor",
    "markdown",
    "react",
    "storybook",
    "toolbar",
    "renderer"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./default-host": {
      "types": "./dist/default-host.d.ts",
      "import": "./dist/default-host.mjs",
      "require": "./dist/default-host.cjs"
    },
    "./panda-primitives": {
      "types": "./dist/panda-primitives.d.ts",
      "import": "./dist/panda-primitives.mjs",
      "require": "./dist/panda-primitives.cjs"
    },
    "./styles.css": "./styled-system/styles.css",
    "./package.json": "./package.json"
  },
  "packageManager": "pnpm@10.18.3",
  "files": [
    "dist",
    "recipes/host-presets",
    "styled-system/styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run prepare && pnpm run clean && tsup",
    "clean": "rm -rf dist",
    "commit": "cz",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "postinstall": "husky",
    "prepack": "pnpm run build",
    "prepare": "panda codegen && panda cssgen --outfile styled-system/styles.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic --project-token=chpt_e7dfd62937e7687 --exit-zero-on-changes",
    "verify:package-surface": "node ./scripts/verify-package-surface.mjs"
  },
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./styled-system/styles.css"
  ],
  "config": {
    "commitizen": {
      "path": "cz-customizable",
      "config": ".cz-config.js"
    }
  },
  "dependencies": {
    "katex": "^0.16.44",
    "mermaid": "^11.13.0",
    "react-markdown": "^10.1.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@pandacss/dev": "^1.9.0",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.27",
    "chromatic": "^16.0.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.3.3",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.6",
    "next": "^15.5.3",
    "prettier": "^3.6.2",
    "storybook": "^10.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^8.0.3",
    "vite-plugin-svgr": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  }
}
