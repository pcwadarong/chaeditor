#!/bin/sh

run_step () {
  NAME=$1
  CMD=$2

  echo "▶ Running $NAME..."
  sh -c "$CMD"
  RESULT=$?

  if [ $RESULT -ne 0 ]; then
    echo "❌ $NAME failed. Push aborted."
    exit 1
  fi
}

run_step "lint" "pnpm run lint"
run_step "type check" "pnpm run check-types"
# test and build run in GitHub Actions for PR merge gating.

echo "✅ All checks passed. Push allowed."
exit 0
